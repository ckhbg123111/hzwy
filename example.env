# Copy this file to .env and adjust values for your environment.

IMAGE_NAME=boardgame-platform-server
CONTAINER_NAME=boardgame-platform-server
HOST_PORT=8079
CONTAINER_PORT=8079
RESTART_POLICY=unless-stopped

# Replace this with a production secret before deployment.
BOARDGAME_OPS_TOKEN=change-me

# Optional Spring profile, for example: prod
SPRING_PROFILES_ACTIVE=

# Optional JVM flags.
JAVA_OPTS=-Xms256m -Xmx512m
